\@writefile{toc}{\contentsline {subsection}{\numberline {5.15.2}Prediction vs Actual Price Comparison}{52}{subsection.5.15.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces  \textbf  {Time-Series Forecast Validation for Tomato Prices (Kolar Mandi).} The solid blue line represents the actual modal price, while the dashed green line shows the predicted price generated by the ensemble model. The vertical dotted line indicates the \textit  {train-test split}. Shaded regions highlight under-prediction and over-prediction areas. The model demonstrates strong tracking of trends with minor deviations during high-volatility periods. }}{52}{figure.caption.26}\protected@file@percent }
\newlabel{fig:forecast_validation}{{5.2}{52}{\textbf {Time-Series Forecast Validation for Tomato Prices (Kolar Mandi).} The solid blue line represents the actual modal price, while the dashed green line shows the predicted price generated by the ensemble model. The vertical dotted line indicates the \textit {train-test split}. Shaded regions highlight under-prediction and over-prediction areas. The model demonstrates strong tracking of trends with minor deviations during high-volatility periods}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.15.3}Residual Error Analysis}{53}{subsection.5.15.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.3}{\ignorespaces  \textbf  {Distribution of Prediction Residuals ($y - \hat  {y}$).} The histogram shows the frequency distribution of prediction errors, while the smooth curve represents the density estimation. The vertical dashed red line indicates the \textit  {mean error}. The near-symmetric shape around zero suggests that the model is \textbf  {unbiased} and does not systematically over-predict or under-predict. }}{54}{figure.caption.27}\protected@file@percent }
\newlabel{fig:residual_distribution}{{5.3}{54}{\textbf {Distribution of Prediction Residuals ($y - \hat {y}$).} The histogram shows the frequency distribution of prediction errors, while the smooth curve represents the density estimation. The vertical dashed red line indicates the \textit {mean error}. The near-symmetric shape around zero suggests that the model is \textbf {unbiased} and does not systematically over-predict or under-predict}{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.15.4}Error Distribution Analysis (Boxplot)}{55}{subsection.5.15.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces  \textbf  {Boxplot of Prediction Errors.} The central line represents the median error, while the box captures the interquartile range (IQR). Whiskers indicate the spread of typical values, and points beyond whiskers represent \textit  {outliers}. The compact box around zero suggests that most prediction errors are small and centered. }}{55}{figure.caption.28}\protected@file@percent }
\newlabel{fig:error_boxplot}{{5.4}{55}{\textbf {Boxplot of Prediction Errors.} The central line represents the median error, while the box captures the interquartile range (IQR). Whiskers indicate the spread of typical values, and points beyond whiskers represent \textit {outliers}. The compact box around zero suggests that most prediction errors are small and centered}{figure.caption.28}{}}
