# Application Environment Settings
APP__ENVIRONMENT=development
APP__DEBUG=true

# Distributed System Logging
LOGGING__LEVEL=DEBUG

# Optional overrides for data configuration
DATA__MISSING_VALUE_TOLERANCE=0.3

# Future API Configuration
# API_SECRET_KEY=your_development_secret_key_here
# DATABASE_URL=postgresql://user:pass@localhost:5432/mandisense

# Docker/Runtime credentials (set real values in .env, never commit .env)
POSTGRES_USER=mandisense
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mandisense_db
DATABASE_URL=postgresql://mandisense:change_me_strong_password@db:5432/mandisense_db
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_password
