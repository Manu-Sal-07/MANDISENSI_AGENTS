# ==============================================================================
# MandiSense AI — Root Backend Environment Variables Contract
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. REQUIRED VARIABLES (Production & Local)
# ------------------------------------------------------------------------------

# PostgreSQL connection string
# Production: Render Database connection string
# Local: postgresql://user:pass@localhost:5432/mandisense
DATABASE_URL=postgresql://user:pass@localhost:5432/mandisense

# Redis connection string
# Production: Render Cache connection string
# Local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# BBC News API Key (Access credentials for News API v2)
# Required to fetch news articles for external factor predictions.
NEWS_API_KEY=your_news_api_key_here

# ------------------------------------------------------------------------------
# 2. OPTIONAL VARIABLES / PRODUCTION SETTINGS
# ------------------------------------------------------------------------------

# Application Environment (e.g., development, production, test)
# Set to 'production' on Render
APP__ENVIRONMENT=production

# Server listening port (Render sets this dynamically)
PORT=8000

# Rate limiting for API requests (requests per second per client IP)
RATE_LIMIT_PER_SECOND=60

# ------------------------------------------------------------------------------
# 3. DEVELOPMENT / DEBUG SETTINGS
# ------------------------------------------------------------------------------

# Enable debug mode and interactive API documentation (e.g., swagger)
# Set to 'false' in production.
APP__DEBUG=false

# Logger verbosity level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOGGING__LEVEL=INFO

# Permit all cross-origin requests (CORS).
# Set to 'false' in production if web access should be restricted to trusted domains.
CORS_ALLOW_ALL_ORIGINS=true
